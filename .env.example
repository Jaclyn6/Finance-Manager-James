# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored. Never commit real secrets.

# ---- Supabase ----
# From: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret>

# ---- Data sources ----
# FRED API key: https://fred.stlouisfed.org/docs/api/api_key.html (free)
FRED_API_KEY=<fred-api-key>

# Alpha Vantage (Phase 2+): https://www.alphavantage.co/support/#api-key (free, 25/day)
ALPHA_VANTAGE_API_KEY=<alpha-vantage-key>

# ---- Vercel Cron protection ----
# Random 32+ char string. Used to authenticate the cron Route Handler.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
CRON_SECRET=<random-32-char-string>
